<div class="row">
  <% for post in @posts %>
    <div class="col-3">
      <% user = User.find_by({ "id" => post["user_id"] }) %>
      <% if user != nil %>
        <h4> 
            <%= user["first_name"] %>
        </h4>
      <% else %>
        <h4>
          anonymous
        </h4>
      <% end %>
      <img src="<%= post["image"] %>" class="img-fluid w-full">
      <p><%= post["body"] %></p>

      <% comments = Comment.where({ "post_id" => post["id"] })%>
      <% for comment in comments %>
        <p>
          <strong><%= User.find_by({ "id" => comment["user_id"] })["first_name"] %>:</strong>
          <%= comment["body"] %>
        </p>
      <% end %>

      <% if @current_user != nil %>
        <form action="/comments" method="post">
          <input type="hidden" name="post_id" value="<%= post["id"] %>">
          <input type="text" name="body" id="body_input">
          <button>Post</button>
          <a href="/posts">Cancel</a>
        </form>
      <% end %>

    </div>
  <% end %>
</div>