<div class="row">
  <% for post in @posts %>
    <div class="col-3">
      <% user = User.find_by({ "id" => post["user_id"] }) %>
      <% if user != nil %>
        <h4> 
            <%= user["first_name"] %>
        </h4>
      <% else %>
        <h4>
          anonymous
        </h4>
      <% end %>
      <img src="<%= post["image"] %>" class="img-fluid w-full">
      <p><%= post["body"] %></p>
    </div>
  <% end %>
</div>